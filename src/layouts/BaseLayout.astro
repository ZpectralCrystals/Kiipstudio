---
import '../styles/global.css';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
const fontStylesheet =
  'https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,700;9..40,800;9..40,900&family=Inter:wght@700&display=swap';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={fontStylesheet} as="style" />
    <link href={fontStylesheet} rel="stylesheet" media="print" onload="this.setAttribute('media','all')" />
    <noscript><link href={fontStylesheet} rel="stylesheet" /></noscript>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
