---
import HomeFigmaLanding from '@features/home/components/HomeFigmaLanding.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getHomeLandingContent } from '@shared/lib/sanity';

const content = await getHomeLandingContent();
---

<BaseLayout
  title="KlipStudio | Eventos, fotos y video"
  description="Landing estática KlipStudio replicada desde Figma con Astro, WebP, lazy loading y carrusel sin librerías."
>
  <main class="min-h-screen bg-[#04000a]">
    <HomeFigmaLanding content={content} />
  </main>
</BaseLayout>
