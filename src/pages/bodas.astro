---
import FooterSlice from '@features/home/components/FooterSlice.astro';
import HeaderSlice from '@features/home/components/HeaderSlice.astro';
import ServiceDetailSlice from '@features/home/components/ServiceDetailSlice.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import {getHomeLandingContent, getServicePage} from '@shared/lib/sanity';

const [content, section] = await Promise.all([getHomeLandingContent(), getServicePage('bodas')]);
if (!section) throw new Error('Sanity service missing: bodas');
---

<BaseLayout title={`${section.title} | KlipStudio`} description={section.seoDescription || section.title}>
  <main class="min-h-screen bg-[#04000a]">
    <HeaderSlice content={content} />
    <ServiceDetailSlice section={section} whatsappUrl={content.whatsappUrl} />
    <FooterSlice content={content} />
  </main>
</BaseLayout>
