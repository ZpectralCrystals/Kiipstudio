---
import ResponsiveCloudinaryPicture from '@shared/components/ResponsiveCloudinaryPicture.astro';
import { homeContent } from '../data/homeContent';
import { bodasContent } from '../data/bodasContent';

const videoSlides = [bodasContent.video.youtubeId, 'ysz5S6PUM-U', 'M7lc1UVf-VE'].filter(Boolean);
const chunkGallery = <T,>(items: T[], size = 8) =>
  Array.from({ length: Math.ceil(items.length / size) }, (_, index) => items.slice(index * size, index * size + size));
const galleryPages = chunkGallery(bodasContent.gallery);
const youtubeSrcdoc = (youtubeId: string, title: string, posterUrl: string) => `
<style>
*{box-sizing:border-box}body{margin:0}.wrap{position:absolute;inset:0;display:grid;place-items:center;background:#000 url(${posterUrl}) center/cover no-repeat}.wrap:before{content:"";position:absolute;inset:0;background:rgba(0,0,0,.25)}.play{position:relative;width:84px;height:84px;border-radius:999px;background:#ff0004;color:#fff;display:grid;place-items:center;font:700 34px/1 sans-serif;text-decoration:none}
</style>
<a class="wrap" href="https://www.youtube.com/embed/${youtubeId}?autoplay=1" aria-label="${title}"><span class="play">▶</span></a>`;
---

<section id="bodas" class="overflow-hidden bg-white text-[#04000a]">
  <div class="relative isolate flex min-h-[330px] items-center justify-center overflow-hidden md:min-h-[494px]">
    <ResponsiveCloudinaryPicture
      localMobileSrc={bodasContent.hero.localMobileSrc}
      localDesktopSrc={bodasContent.hero.localDesktopSrc}
      alt="Decoración de boda KlipStudio"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      eager
      mobileWidth={900}
      desktopWidth={1920}
      intrinsicWidth={1920}
      intrinsicHeight={494}
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-black/80 via-black/45 to-transparent"></div>
    <div class="px-5 text-center text-white">
      <h2 class="text-5xl font-bold uppercase leading-none md:text-[60px]">{bodasContent.title}</h2>
      <div class="mt-3 flex items-center justify-center gap-3 text-sm font-bold capitalize md:text-2xl">
        <a href="#bodas-fotos" class="transition duration-200 hover:text-[#ff0004]">Fotos</a>
        <span>›</span>
        <a href="#bodas-videos" class="transition duration-200 hover:text-[#ff0004]">Videos</a>
      </div>
    </div>
  </div>

  <div id="bodas-fotos" class="mx-auto max-w-[1290px] px-5 py-14 md:px-8 md:py-20">
    <div class="mb-8 flex items-center justify-center gap-4 text-2xl font-medium capitalize md:text-[32px]">
      <span class="text-[#d60000]">Fotos</span>
      <span class="text-[#848484]">›</span>
      <a href="#bodas-videos" class="text-[#666666] transition duration-200 hover:text-[#d60000]">Videos</a>
    </div>

    <div class="relative" data-gallery-slider>
      <button class="absolute left-0 top-1/2 z-10 hidden size-12 -translate-x-4 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Fotos anteriores" data-gallery-prev>‹</button>
      <div class="gallery-track flex overflow-x-auto scroll-smooth pb-4" data-gallery-track>
        {
          galleryPages.map((page, pageIndex) => (
            <div class="grid min-w-full grid-cols-2 gap-4 md:grid-cols-4 md:gap-7" data-gallery-page>
              {
                page.map((item, itemIndex) => {
                  const absoluteIndex = pageIndex * 8 + itemIndex;
                  return (
                    <ResponsiveCloudinaryPicture
                      localMobileSrc={item.localMobileSrc}
                      localDesktopSrc={item.localDesktopSrc}
                      alt={item.alt}
                      class="aspect-[410/524] w-full object-cover"
                      eager={absoluteIndex < 2}
                      mobileWidth={520}
                      desktopWidth={820}
                      intrinsicWidth={410}
                      intrinsicHeight={524}
                    />
                  );
                })
              }
            </div>
          ))
        }
      </div>
      <button class="absolute right-0 top-1/2 z-10 hidden size-12 translate-x-4 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Fotos siguientes" data-gallery-next>›</button>
    </div>

    <nav class="mt-8 flex justify-center gap-1" aria-label="Paginación fotos">
      {
        galleryPages.map((_, index) => (
          <button
            type="button"
            class="grid size-11 place-items-center rounded-full"
            aria-label={`Ir a fotos ${index + 1}`}
            aria-current={index === 0 ? 'page' : undefined}
            data-gallery-dot
          >
            <span class={`block size-2.5 rounded-full ${index === 0 ? 'bg-[#ff0004]' : 'bg-[#d9d9d9]'}`} data-gallery-dot-indicator></span>
          </button>
        ))
      }
    </nav>
  </div>

  <div id="bodas-videos" class="mx-auto max-w-[1740px] px-5 pb-14 md:px-8 md:pb-20">
    <div class="mb-8 flex items-center justify-center gap-4 text-2xl font-medium capitalize md:text-[32px]">
      <span class="text-[#d60000]">Videos</span>
      <span class="text-[#848484]">›</span>
      <a href="#bodas-fotos" class="text-[#666666] transition duration-200 hover:text-[#d60000]">Fotos</a>
    </div>

    <div class="relative" data-gallery-slider>
      <button class="absolute left-0 top-1/2 z-10 hidden size-12 -translate-x-4 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Video anterior" data-gallery-prev>‹</button>
      <div class="gallery-track mx-auto flex max-h-[620px] overflow-x-auto scroll-smooth" data-gallery-track>
        {videoSlides.map((youtubeId, index) => (
          <div class="relative aspect-[1740/974] min-w-full overflow-hidden" data-gallery-page>
            {/* Videos stay on YouTube so static hosting never serves heavy video files. */}
            <iframe
              class="h-full w-full"
              srcdoc={youtubeSrcdoc(youtubeId, `${bodasContent.video.title} ${index + 1}`, bodasContent.video.localDesktopSrc)}
              title={`${bodasContent.video.title} ${index + 1}`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
          />
        </div>
      ))}
      </div>
      <button class="absolute right-0 top-1/2 z-10 hidden size-12 translate-x-4 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Video siguiente" data-gallery-next>›</button>
    </div>

    <nav class="mt-8 flex justify-center gap-1" aria-label="Paginación videos">
      {
        videoSlides.map((_, index) => (
          <button
            type="button"
            class="grid size-11 place-items-center rounded-full"
            aria-label={`Ir a video ${index + 1}`}
            aria-current={index === 0 ? 'page' : undefined}
            data-gallery-dot
          >
            <span class={`block size-2.5 rounded-full ${index === 0 ? 'bg-[#ff0004]' : 'bg-[#d9d9d9]'}`} data-gallery-dot-indicator></span>
          </button>
        ))
      }
    </nav>
  </div>

  <div id="bodas-paquetes" class="mx-auto max-w-[1290px] px-5 pb-20 md:px-8 md:pb-28">
    <p class="text-sm font-medium uppercase tracking-[0.12em] text-[#d60000] md:text-lg">{bodasContent.packages.eyebrow}</p>
    <h2 class="mt-2 text-4xl font-bold uppercase leading-none md:text-[64px]">{bodasContent.packages.title}</h2>

    <div class="mt-8 grid gap-8 md:grid-cols-3">
      {
        bodasContent.packages.plans.map((plan) => (
          <article class="overflow-hidden rounded-[20px] bg-white shadow-[0_4px_20px_-1px_rgba(19,16,34,0.12)] ring-1 ring-black/5">
            <div class="relative isolate flex min-h-56 flex-col items-center justify-center overflow-hidden bg-[#ff0004] px-6 text-center text-white">
              {/* Layered red header follows Figma package-card geometry without storing decorative SVGs. */}
              <div class="absolute inset-x-0 bottom-6 h-16 translate-x-20 skew-x-[-18deg] bg-white/20"></div>
              <div class="absolute inset-x-0 bottom-0 h-14 -translate-x-24 skew-x-[18deg] bg-white/10"></div>
              <p class="relative text-4xl font-bold leading-tight md:text-5xl">{plan.price}</p>
              <h3 class="relative mt-2 text-2xl font-bold capitalize md:text-3xl">{plan.name}</h3>
            </div>

            <div class="flex min-h-[340px] flex-col px-8 py-9">
              <ul class="flex-1 list-disc space-y-3 pl-5 text-sm leading-6 text-[#666666]">
                {plan.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
              <a
                href={homeContent.whatsappUrl}
                class={`mt-8 inline-flex items-center justify-center rounded-full px-6 py-4 text-xs font-bold uppercase tracking-[0.12em] transition duration-200 hover:-translate-y-0.5 ${
                  plan.featured
                    ? 'bg-[#ff0004] text-[#04000a] hover:bg-red-500'
                    : 'border border-[#cccccc] text-[#04000a] hover:border-[#d60000] hover:text-[#d60000]'
                }`}
              >
                Agenda ahora →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  import '../scripts/gallery-slider.js';
</script>
