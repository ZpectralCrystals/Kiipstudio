---
import type {HomeLandingContent} from '../data/homeContent';
import {getOptimizedCloudinaryUrl} from '@shared/lib/cloudinary';

type Props = {content: HomeLandingContent};
const {content} = Astro.props;
const remoteLogoSrc = 'imageUrl' in content.logo ? content.logo.imageUrl : undefined;
const logoSrc = getOptimizedCloudinaryUrl(typeof remoteLogoSrc === 'string' ? remoteLogoSrc : undefined, 320) || content.logo.localSrc;
---

<header class="relative mx-auto flex h-24 max-w-[1808px] items-center justify-between px-5 md:h-[100px] md:px-0 md:pt-[45px]">
  <a href="/" aria-label="KlipStudio inicio" class="block w-24 md:absolute md:left-0 md:top-[47px] md:w-[157px]">
    <img src={logoSrc} alt={content.logo.alt} class="h-auto w-full" loading="eager" decoding="async" width="157" height="45" />
  </a>
  <nav class="hidden items-center gap-[36px] md:absolute md:left-1/2 md:top-[57px] md:flex md:-translate-x-1/2" aria-label="Navegación principal">
    {content.nav.main.map((item) => <a href={item.href} class="text-[15px] font-bold uppercase leading-[26px] tracking-[1.4px] text-white transition duration-200 hover:text-[#ff0004]">{item.label}</a>)}
  </nav>
  <a href={content.whatsappUrl} class="inline-flex min-h-11 items-center justify-center rounded-full bg-[#ff0004] px-5 py-2.5 text-[11px] font-black uppercase tracking-[0.14em] text-[#04000a] transition duration-200 hover:-translate-y-0.5 hover:bg-red-500 md:absolute md:right-5 md:top-[clamp(34px,2.34vw,45px)] md:h-[clamp(36px,2.5vw,48px)] md:w-[clamp(134px,9.27vw,178px)] md:px-0 md:py-0 md:text-center md:text-[clamp(15px,1.04vw,20px)] md:leading-[clamp(36px,2.5vw,48px)] md:tracking-[1.6px] xl:right-8 2xl:right-[-29px]">Whatsapp →</a>
</header>
