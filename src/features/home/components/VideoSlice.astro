---
import { homeContent } from '../data/homeContent';

const { video } = homeContent;
const youtubeSrc = `https://www.youtube.com/embed/${video.youtubeId}`;
---

<section class="border-t border-stone-800 bg-stone-950/50 px-5 py-16 md:px-8">
  <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-[0.8fr_1fr] md:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-300">YouTube</p>
      <h2 class="mt-2 text-2xl font-semibold text-stone-50 md:text-3xl">{video.title}</h2>
      <p class="mt-4 text-sm leading-7 text-stone-300">{video.body}</p>
    </div>

    <div class="mx-auto aspect-[9/16] w-full max-w-sm overflow-hidden rounded-lg border border-stone-800 bg-black shadow-2xl shadow-emerald-950/25">
      <!-- Videos live on YouTube; this keeps static hosting light and mobile-friendly. -->
      <iframe
        class="h-full w-full"
        src={youtubeSrc}
        title={video.title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      />
    </div>
  </div>
</section>
