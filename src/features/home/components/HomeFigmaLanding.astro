---
import { getCloudinaryImageUrl, getOptimizedCloudinaryUrl } from '@shared/lib/cloudinary';
import SocialIcon from '@shared/components/SocialIcon.astro';
import type { HomeLandingContent, LandingImage } from '../data/homeContent';
import HeaderSlice from './HeaderSlice.astro';

type Props = {
  content: HomeLandingContent;
};

const { content } = Astro.props;

const imageSrc = (image: LandingImage, width = 1600, height?: number) =>
  getOptimizedCloudinaryUrl(image.imageUrl, width, height) || (image.cloudinaryPublicId ? getCloudinaryImageUrl({ publicId: image.cloudinaryPublicId, width }) : image.localSrc);
const transparentPixel = 'data:image/gif;base64,R0lGODlhAQABAAAAACw=';
const navLabelByHref = (href: string) => content.nav.main.find((item) => item.href === href)?.label ?? '';
const servicesHeading = navLabelByHref('/#servicios');
const aboutHeading = navLabelByHref('/#nosotros');
const contactHeading = content.studio.buttonLabel;
const whatsappLabel = content.footer.socials.find((item) => item.href === content.whatsappUrl)?.label ?? '';
const whatsappPhone = content.whatsappUrl.match(/\d+/)?.[0] || '51914187890';
const whatsappNormalHref = `whatsapp://send?phone=${whatsappPhone}`;
const howWeWorkNavItem = content.nav.nosotros.find((item) => item.href === '/como-trabajamos');
const emailHref = `mailto:${content.footer.email}`;
const phoneHref = `tel:+51${content.footer.phone.replace(/\D/g, '')}`;
const handleHref = (icon: string, href?: string) => {
  if (href) return href;
  const key = icon.trim().toLowerCase();
  return content.footer.socials.find((item) => item.label.toLowerCase() === key || item.text === icon)?.href || '#';
};
---

<section class="home-figma" aria-label="KlipStudio">
  <div class="home-figma__header">
    <HeaderSlice content={content} activeSection="inicio" />
  </div>

  <div class="home-figma__stage">
    <div class="home-figma__surface">
      <picture>
        <source media="(min-width: 901px)" srcset={imageSrc(content.heroBackground, 1920)} />
        <img class="absolute left-0 top-0 h-[1858px] w-[1920px] object-cover" src={transparentPixel} alt="" loading="eager" decoding="async" />
      </picture>
      <div class="absolute left-[-13px] top-[1140px] h-[756px] w-[1933px] bg-[#ff0000] opacity-[0.09]"></div>
      <span id="servicios" class="page-anchor top-[390px]" aria-hidden="true"></span>
      <span id="nosotros" class="page-anchor top-[965px]" aria-hidden="true"></span>
      <span id="por-que-elegirnos" class="page-anchor top-[2910px]" aria-hidden="true"></span>
      <span id="contacto" class="page-anchor top-[4931px]" aria-hidden="true"></span>

      <main>
        <section aria-labelledby="home-work-title">
          <h1 id="home-work-title" class="absolute left-1/2 top-[267px] h-[58px] w-[1160px] -translate-x-1/2 text-center text-[48px] font-bold uppercase leading-[58px] tracking-[1.4px] text-white">
            {content.headline}
          </h1>

          <div class="absolute left-[93px] top-[401px] grid grid-cols-5 gap-[23px]">
            {
              content.serviceCards.map((card) => (
                <a class="block w-[328px]" href={card.href} aria-label={`Ver ${card.title}`}>
                  <picture>
                    <source media="(min-width: 901px)" srcset={imageSrc(card.image, 720, 1014)} />
                    <img class="h-[462px] w-[328px] rounded-[26px] object-cover" src={transparentPixel} alt={card.image.alt} loading="eager" decoding="async" />
                  </picture>
                  <h2 class="mt-[25px] text-center text-[24px] font-medium uppercase leading-[31px] text-white">{card.title}</h2>
                </a>
              ))
            }
          </div>
        </section>

        <section aria-labelledby="about-title">
          <img class="absolute left-[144px] top-[965px] h-[913px] w-[628px] object-contain" src={imageSrc(content.about.person, 900)} alt={content.about.person.alt} loading="lazy" decoding="async" />
          <h2 id="about-title" class="absolute left-[942px] top-[1285px] w-[615px] text-[64px] font-bold uppercase leading-[64px] tracking-[1.4px] text-white">
            {content.about.title}
          </h2>
          <div class="absolute left-[897px] top-[1359px] w-[705px] text-justify text-[32px] font-normal leading-[35px] text-white">
            {content.about.body.map((paragraph) => <p class="mb-0">{paragraph}</p>)}
          </div>
          <img class="absolute left-[1413px] top-[1472px] h-[675px] w-[675px] -rotate-[90.86deg] object-contain" src={imageSrc(content.about.camera, 900)} alt="" loading="lazy" decoding="async" />
        </section>

        <section aria-label="Estudio favorito en Arequipa">
          <img class="absolute left-[-32px] top-[1844px] h-[1066px] w-[2017px] object-cover" src={imageSrc(content.studio.image, 1920)} alt={content.studio.image.alt} loading="lazy" decoding="async" />
          <p class="absolute left-[239px] top-[2040px] whitespace-nowrap text-[48px] font-normal leading-[56px] tracking-[1.4px] text-black">{content.studio.eyebrow}</p>
          <p class="absolute left-[239px] top-[2093px] whitespace-nowrap text-[64px] font-bold leading-[56px] tracking-[1.4px] text-[#ff0004]">{content.studio.highlight}</p>
          <p class="absolute left-[408px] top-[2146px] whitespace-nowrap text-[55px] font-black leading-[56px] tracking-[1.4px] text-black">{content.studio.suffix}</p>
          <a class="absolute left-[535px] top-[2224px] flex h-[52px] w-[220px] items-center justify-center rounded-[12px] bg-[#ff0004] text-[32px] font-black leading-[39px] tracking-[-1px] text-white" href={content.whatsappUrl}>
            {content.studio.buttonLabel}
          </a>
        </section>

        <section aria-labelledby="why-title">
          <img class="absolute left-[-1px] top-[2910px] h-[1118px] w-[2120px] object-cover" src={imageSrc(content.why.background, 1920)} alt={content.why.background.alt} loading="lazy" decoding="async" />
          <h2 id="why-title" class="absolute left-[1218px] top-[3088px] w-[490px] text-right text-[48px] font-medium leading-[39px] tracking-[1.4px] text-black">
            {content.why.title}
          </h2>
          <div class="absolute left-[1195px] top-[3186px] grid gap-[45px]">
            {
              content.why.items.map((item) => (
                <div class="flex min-h-[94px] w-[610px] gap-[19px]">
                  <span class="relative mt-[2px] block h-[47px] w-[49px] shrink-0">
                    <span class="absolute left-0 top-[2px] block h-[46px] w-[46px] border-4 border-[#ff0004]"></span>
                    <img class="absolute left-[6px] top-0 h-[47px] w-[49px] object-contain" src={imageSrc(content.why.check, 96)} alt="" loading="lazy" decoding="async" />
                  </span>
                  <p class="w-[518px] text-[28px] font-normal leading-normal text-[#505050]">{item}</p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="absolute left-0 top-[4018px] z-10 grid h-[887px] w-[1920px] grid-cols-3" aria-label="Galería de retratos">
          {content.gallery.slice(0, 3).map((image) => <img class="h-full w-full object-cover" src={imageSrc(image, 900)} alt={image.alt} loading="lazy" decoding="async" />)}
        </section>
      </main>

      <div class="absolute left-0 top-[4905px] z-30 h-[26px] w-[1920px] bg-[#ff0000]" aria-hidden="true"></div>

      <footer class="absolute left-0 top-[4931px] z-20 h-[543px] w-[1920px] bg-[#04000a] text-white">
        <img class="absolute left-[250px] top-[84px] h-[57px] w-[202px] object-contain" src={imageSrc(content.logo, 320)} alt={content.logo.alt} loading="lazy" decoding="async" />
        <nav class="absolute left-[1542px] top-[111px] flex gap-[28px]" aria-label="Redes sociales">
          {content.footer.socials.map((item) => <a class="grid size-[20px] place-items-center hover:opacity-70" href={item.href} aria-label={item.label}><SocialIcon name={item.label} variant="white" class="h-[18px] w-[18px] object-contain" /></a>)}
        </nav>
        <img class="absolute left-[259px] top-[153px] h-px w-[1410px]" src="/assets/figma/home-v2/line-footer.svg" alt="" />

        <div class="absolute left-[259px] top-[197px]">
          <h2 class="mb-[26px] text-[24px] font-bold uppercase leading-[34px]">{servicesHeading}</h2>
          <ul class="space-y-[14px] text-[16px] leading-[24px] text-white/90">
            {content.nav.servicios.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          </ul>
        </div>

        <div class="absolute left-[499px] top-[197px]">
          <h2 class="mb-[26px] text-[24px] font-bold uppercase leading-[34px]">{aboutHeading}</h2>
          <ul class="space-y-[15px] text-[16px] leading-[24px] text-white/90">
            {content.nav.nosotros.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          </ul>
        </div>

        <div class="absolute left-[756px] top-[197px]">
          <h2 class="mb-[30px] text-[24px] font-bold uppercase leading-[34px]">{contactHeading}</h2>
          <ul class="space-y-[10px] text-[16px] font-semibold leading-[24px] text-white/90">
            <li><a class="flex items-center gap-[14px]" href={emailHref}><span class="contact-dot"><SocialIcon name="email" class="h-[18px] w-[20px] object-contain" /></span>{content.footer.email}</a></li>
            <li><a class="flex items-center gap-[14px]" href={phoneHref}><span class="contact-dot"><SocialIcon name="phone" class="h-[21px] w-[21px] object-contain" /></span>{content.footer.phone}</a></li>
            {content.footer.handles.map((item) => <li><a class="flex items-center gap-[14px]" href={handleHref(item.icon, item.href)}><span class="contact-dot"><SocialIcon name={item.icon} class="h-[18px] w-[18px] object-contain" /></span>{item.text}</a></li>)}
          </ul>
        </div>
      </footer>
    </div>
  </div>

  <div class="home-mobile" aria-label="KlipStudio móvil">
    <header class="mobile-header">
      <a href="/" aria-label="KlipStudio inicio">
        <img class="mobile-header__logo" src={imageSrc(content.logo, 320)} alt={content.logo.alt} loading="eager" decoding="async" />
      </a>
      <a class="mobile-header__cta" href={content.whatsappUrl} data-mobile-whatsapp-href={whatsappNormalHref} data-whatsapp-fallback={content.whatsappUrl}>{whatsappLabel} <span aria-hidden="true">→</span></a>
    </header>

    <nav class="mobile-nav" aria-label="Navegación principal móvil">
      {content.nav.main.map((item) => <a href={item.href}>{item.label}</a>)}
      {howWeWorkNavItem && <a href={howWeWorkNavItem.href}>{howWeWorkNavItem.label}</a>}
    </nav>

    <main>
      <section class="mobile-hero" data-mobile-anchor="servicios" aria-labelledby="mobile-services-title">
        <div class="mobile-hero__bg" aria-hidden="true"></div>
        <h1 id="mobile-services-title">{content.headline}</h1>
        <div class="mobile-services-carousel" data-services-carousel>
          <div class="mobile-services" aria-label={servicesHeading} tabindex="0" data-carousel-track>
            {
              content.serviceCards.map((card, index) => (
                <a class="mobile-service-card" href={card.href} aria-label={`Ver ${card.title}`}>
                  <img src={imageSrc(card.image, 430, 606)} alt={card.image.alt} loading={index === 0 ? 'eager' : 'lazy'} fetchpriority={index === 0 ? 'high' : 'low'} decoding="async" />
                  <span>{card.title}</span>
                </a>
              ))
            }
          </div>
          <div class="mobile-carousel-controls">
            <button class="mobile-carousel-button" type="button" aria-label="Servicio anterior" data-carousel-prev>‹</button>
            <div class="mobile-carousel-dots" aria-hidden="true">
              {content.serviceCards.map((_, index) => <span class={index === 0 ? 'is-active' : ''} data-carousel-dot></span>)}
            </div>
            <button class="mobile-carousel-button" type="button" aria-label="Servicio siguiente" data-carousel-next>›</button>
          </div>
        </div>
      </section>

      <section class="mobile-about" data-mobile-anchor="nosotros" aria-labelledby="mobile-about-title">
        <div class="mobile-about__copy">
          <h2 id="mobile-about-title">{content.about.title}</h2>
          {content.about.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <img class="mobile-about__person" src={imageSrc(content.about.person, 760)} alt={content.about.person.alt} loading="lazy" decoding="async" />
        <img class="mobile-about__camera" src={imageSrc(content.about.camera, 560)} alt="" loading="lazy" decoding="async" />
      </section>

      <section class="mobile-studio" aria-label="Estudio favorito en Arequipa">
        <div class="mobile-studio__copy">
          <p>{content.studio.eyebrow}</p>
          <strong>{content.studio.highlight}</strong>
          <span>{content.studio.suffix}</span>
          <a href={content.whatsappUrl}>{content.studio.buttonLabel}</a>
        </div>
        <img src={imageSrc(content.studio.image, 900)} alt={content.studio.image.alt} loading="lazy" decoding="async" />
      </section>

      <section class="mobile-why" data-mobile-anchor="por-que-elegirnos" aria-labelledby="mobile-why-title">
        <img class="mobile-why__image" src={imageSrc(content.why.background, 900)} alt={content.why.background.alt} loading="lazy" decoding="async" />
        <div class="mobile-why__copy">
          <h2 id="mobile-why-title">{content.why.title}</h2>
          <ul>
            {
              content.why.items.map((item) => (
                <li>
                  <span aria-hidden="true">✓</span>
                  <p>{item}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="mobile-gallery" aria-label="Galería de retratos">
        {content.gallery.map((image) => <img src={imageSrc(image, 900)} alt={image.alt} loading="lazy" decoding="async" />)}
      </section>
    </main>

    <footer class="mobile-footer" data-mobile-anchor="contacto">
      <img class="mobile-footer__logo" src={imageSrc(content.logo, 220)} alt={content.logo.alt} loading="lazy" decoding="async" />
      <div class="mobile-footer__grid">
        <div>
          <h2>{servicesHeading}</h2>
          {content.nav.servicios.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
        <div>
          <h2>{aboutHeading}</h2>
          {content.nav.nosotros.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
        <div>
          <h2>{contactHeading}</h2>
          <a href={emailHref}>{content.footer.email}</a>
          <a href={phoneHref}>{content.footer.phone}</a>
          {content.footer.handles.map((item) => <a class="mobile-footer__handle" href={handleHref(item.icon, item.href)}><SocialIcon name={item.icon} class="h-4 w-4 object-contain" />{item.text}</a>)}
        </div>
      </div>
    </footer>
  </div>
</section>

<script>
  const figmaScrollTargets = {
    '#servicios': 390,
    '#nosotros': 965,
    '#por-que-elegirnos': 2910,
    '#contacto': 4931,
  };

  const mobileScrollTargets = {
    '#servicios': 'servicios',
    '#nosotros': 'nosotros',
    '#por-que-elegirnos': 'por-que-elegirnos',
    '#contacto': 'contacto',
  };

  const getHomeScale = () => {
    const stage = document.querySelector('.home-figma__stage');
    return stage ? stage.getBoundingClientRect().height / 5474 : 1;
  };

  const scrollToFigmaTarget = (hash: string, behavior: ScrollBehavior = 'smooth') => {
    const mobileTarget = mobileScrollTargets[hash as keyof typeof mobileScrollTargets];
    if (window.matchMedia('(max-width: 900px)').matches && mobileTarget) {
      const target = document.querySelector(`[data-mobile-anchor="${mobileTarget}"]`);
      if (target instanceof HTMLElement) target.scrollIntoView({ behavior, block: 'start' });
      return;
    }

    const target = figmaScrollTargets[hash as keyof typeof figmaScrollTargets];
    if (target === undefined) return;
    window.scrollTo({ top: target * getHomeScale(), behavior });
  };

  window.addEventListener('DOMContentLoaded', () => {
    if (window.location.hash) {
      window.setTimeout(() => scrollToFigmaTarget(window.location.hash, 'auto'), 0);
    }
  });

  window.addEventListener('hashchange', () => scrollToFigmaTarget(window.location.hash));

  document.addEventListener('click', (event) => {
    const link = (event.target as Element).closest('a[href^="/#"], a[href^="#"]');
    if (!(link instanceof HTMLAnchorElement)) return;

    const url = new URL(link.href);
    if (url.pathname !== window.location.pathname) return;
    if (!(url.hash in figmaScrollTargets)) return;

    event.preventDefault();
    history.pushState(null, '', url.hash);
    scrollToFigmaTarget(url.hash);
  });

  const setupServicesCarousel = () => {
    const carousel = document.querySelector('[data-services-carousel]');
    if (!carousel) return;

    const track = carousel.querySelector<HTMLElement>('[data-carousel-track]');
    const cards = Array.from(carousel.querySelectorAll<HTMLElement>('.mobile-service-card'));
    const dots = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-dot]'));
    const prev = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]');
    if (!track || cards.length === 0) return;

    const currentIndex = () => {
      const trackCenter = track.scrollLeft + track.clientWidth / 2;
      return cards.reduce((bestIndex, card, index) => {
        const bestCard = cards[bestIndex];
        const cardCenter = card.offsetLeft + card.offsetWidth / 2;
        const bestCenter = bestCard.offsetLeft + bestCard.offsetWidth / 2;
        return Math.abs(cardCenter - trackCenter) < Math.abs(bestCenter - trackCenter) ? index : bestIndex;
      }, 0);
    };

    const update = () => {
      const index = currentIndex();
      dots.forEach((dot, dotIndex) => dot.classList.toggle('is-active', dotIndex === index));
      if (prev) prev.disabled = index === 0;
      if (next) next.disabled = index === cards.length - 1;
    };

    const scrollToCard = (index: number) => {
      const card = cards[Math.max(0, Math.min(cards.length - 1, index))];
      track.scrollTo({ left: card.offsetLeft - (track.clientWidth - card.offsetWidth) / 2, behavior: 'smooth' });
    };

    prev?.addEventListener('click', () => scrollToCard(currentIndex() - 1));
    next?.addEventListener('click', () => scrollToCard(currentIndex() + 1));
    dots.forEach((dot, index) => dot.addEventListener('click', () => scrollToCard(index)));
    track.addEventListener('scroll', () => window.requestAnimationFrame(update), { passive: true });
    window.addEventListener('resize', update);
    update();
  };

  window.addEventListener('DOMContentLoaded', setupServicesCarousel);
</script>

<style>
  .home-figma {
    background: #04000a;
    overflow: hidden;
    position: relative;
    width: 100vw;
  }

  .home-figma__header {
    left: 0;
    position: absolute;
    top: 0;
    width: 100vw;
    z-index: 40;
  }

  .home-mobile {
    display: none;
  }

  .home-figma__stage {
    --home-scale: calc(100vw / 1920px);
    height: 285.1041666667vw;
    position: relative;
    width: 100%;
  }

  .home-figma__surface {
    background: #04000a;
    height: 5474px;
    left: 0;
    position: absolute;
    top: 0;
    transform: scale(var(--home-scale));
    transform-origin: top left;
    width: 1920px;
  }

  .home-figma__surface img {
    max-width: none;
  }

  .nav-main {
    color: white;
    display: block;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 1.4px;
    line-height: 26px;
    text-transform: uppercase;
  }

  .nav-main--active {
    border-bottom: 4px solid #ff0004;
    padding-bottom: 11px;
  }

  .page-anchor {
    height: 1px;
    left: 0;
    pointer-events: none;
    position: absolute;
    width: 1px;
  }

  .menu-panel {
    background: rgba(49, 38, 38, 0.86);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
    pointer-events: none;
  }

  .group:hover .menu-panel,
  .group:focus-within .menu-panel {
    pointer-events: auto;
  }

  .menu-link {
    color: white;
    display: block;
    font-size: 16px;
    font-weight: 600;
    line-height: 20px;
    margin-bottom: 9px;
    opacity: 0.9;
    white-space: nowrap;
  }

  .contact-dot {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    color: #ff0004;
    display: inline-flex;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  @media (max-width: 900px) {
    .home-figma {
      background: #04000a;
      overflow: visible;
    }

    .home-figma__stage {
      display: none;
    }

    .home-figma__header {
      background: linear-gradient(180deg, rgba(17, 0, 0, 0.98), rgba(17, 0, 0, 0.86));
      display: block;
      position: sticky;
      top: 0;
      z-index: 60;
    }

    .home-mobile {
      background: #05000a;
      color: white;
      display: block;
      min-height: 100vh;
      overflow: hidden;
      width: 100%;
    }

    .mobile-header {
      display: none;
    }

    .mobile-header__logo {
      height: 32px;
      object-fit: contain;
      width: 112px;
    }

    .mobile-header__cta {
      align-items: center;
      background: #ff0004;
      border-radius: 999px;
      color: white;
      display: inline-flex;
      font-size: 10px;
      font-weight: 900;
      gap: 6px;
      height: 30px;
      justify-content: center;
      letter-spacing: 0;
      padding: 0 12px;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .mobile-nav {
      display: none;
    }

    .mobile-nav::-webkit-scrollbar {
      display: none;
    }

    .mobile-nav a {
      border: 1px solid rgba(255, 255, 255, 0.22);
      border-radius: 999px;
      color: white;
      flex: 1 1 calc(50% - 8px);
      font-size: 11px;
      font-weight: 800;
      line-height: 1;
      padding: 10px 13px;
      text-align: center;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .mobile-hero {
      background: #180101;
      isolation: isolate;
      padding: 34px 18px 42px;
      position: relative;
    }

    .mobile-hero__bg {
      background:
        linear-gradient(180deg, rgba(40, 0, 0, 0.4), #220303),
        url("/assets/figma/home-v2/circle.svg");
      inset: 0;
      opacity: 0.42;
      position: absolute;
      z-index: -1;
    }

    .mobile-hero h1 {
      font-size: clamp(25px, 7.4vw, 34px);
      font-weight: 900;
      line-height: 1.08;
      margin: 0 auto 24px;
      max-width: 420px;
      text-align: center;
      text-transform: uppercase;
    }

    .mobile-services-carousel {
      margin: 0 -18px;
      position: relative;
    }

    .mobile-services {
      display: flex;
      gap: clamp(46px, 17vw, 72px);
      overflow-x: auto;
      padding: 0 34px 18px;
      scroll-padding: 0 34px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .mobile-services::-webkit-scrollbar {
      display: none;
    }

    .mobile-service-card {
      color: white;
      display: grid;
      flex: 0 0 min(calc(100vw - 68px), 360px);
      gap: 12px;
