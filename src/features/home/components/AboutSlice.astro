---
import { homeContent } from '../data/homeContent';

const youtubeSrcdoc = (youtubeId: string, title: string, posterUrl: string) => `
<style>
*{box-sizing:border-box}body{margin:0}.wrap{position:absolute;inset:0;display:grid;place-items:center;background:#000 url(${posterUrl}) center/cover no-repeat}.wrap:before{content:"";position:absolute;inset:0;background:rgba(0,0,0,.3)}.play{position:relative;width:84px;height:84px;border-radius:999px;background:#ff0004;color:#04000a;display:grid;place-items:center;font:700 34px/1 sans-serif;text-decoration:none}
</style>
<a class="wrap" href="https://www.youtube.com/embed/${youtubeId}?autoplay=1" aria-label="${title}"><span class="play">▶</span></a>`;

const videoPoster = homeContent.categories[0]?.localMobileSrc || '/assets/figma/bodas-mobile.webp';
---

<section id="nosotros" class="px-5 pb-20 md:px-0 md:pb-[175px]">
  <div class="mx-auto grid max-w-[1590px] gap-12 md:grid-cols-[657px_851px] md:gap-[82px] md:items-start">
    <div class="md:pt-[23px]">
      <h2 class="text-4xl font-bold uppercase leading-none tracking-[0.04em] text-white md:text-[64px] md:leading-[64px] md:tracking-[1.4px]">
        ¿Quiénes somos?
      </h2>
      <p class="mt-9 max-w-xl text-justify text-base font-light uppercase leading-6 text-white md:mt-[30px] md:max-w-[657px] md:text-[32px] md:leading-[35px]">
        {homeContent.about.body}
      </p>

      <h3 class="mt-5 text-xl font-extrabold capitalize text-white md:mt-[22px] md:text-[36px] md:leading-[35px]">
        {homeContent.about.specialtiesTitle}
      </h3>
      <ul class="mt-2 list-disc space-y-0.5 pl-6 text-base font-light capitalize leading-5 text-white md:mt-[9px] md:pl-8 md:text-[32px] md:leading-[35px]">
        {homeContent.about.specialties.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="aspect-[851/774] w-full overflow-hidden bg-[#d9d9d9] md:translate-x-[51px]">
      {
        homeContent.video.youtubeId && (
          // Videos are embedded from YouTube only; no heavy video files are served by the static site.
          <iframe
            class="h-full w-full"
            srcdoc={youtubeSrcdoc(homeContent.video.youtubeId, homeContent.video.title, videoPoster)}
            title={homeContent.video.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          />
        )
      }
    </div>
  </div>
</section>
