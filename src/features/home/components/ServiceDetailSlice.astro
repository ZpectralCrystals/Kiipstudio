---
import {getOptimizedCloudinaryUrl} from '@shared/lib/cloudinary';
import type {SanityImage, ServicePageContent} from '@shared/lib/sanity';

type Props = {
  section: ServicePageContent;
  whatsappUrl: string;
};

const {section, whatsappUrl} = Astro.props;
const imageSrc = (image: SanityImage | undefined, width: number, height?: number) => getOptimizedCloudinaryUrl(image?.imageUrl, width, height);
const galleryPages = Array.from({length: Math.ceil(section.gallery.length / 8)}, (_, index) => section.gallery.slice(index * 8, index * 8 + 8));
const youtubeIdFromUrl = (url?: string) => {
  if (!url) return '';
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([^?&/]+)/);
  return match?.[1] || '';
};
const videoId = (video: ServicePageContent['videos'][number]) => video.youtubeId || youtubeIdFromUrl(video.youtubeUrl);
const videos = section.videos.map((video) => ({...video, youtubeId: videoId(video)})).filter((video) => video.youtubeId);
const photoLabel = section.photoLabel || 'Fotos';
const videoLabel = section.videoLabel || 'Videos';
const packageGridClass = `packages-grid packages-grid--${Math.min(Math.max(section.packages?.plans?.length || 0, 2), 4)}`;
const planSections = (plan: ServicePageContent['packages']['plans'][number]) =>
  plan.sections?.length ? plan.sections : [{heading: '', items: plan.bullets || []}];
const youtubeSrcdoc = (youtubeId: string, title: string, posterUrl: string) => `
<style>
*{box-sizing:border-box}body{margin:0}.wrap{position:absolute;inset:0;display:grid;place-items:center;background:#000 url(${posterUrl}) center/cover no-repeat}.wrap:before{content:"";position:absolute;inset:0;background:rgba(0,0,0,.25)}.play{position:relative;width:84px;height:84px;border-radius:999px;background:#ff0004;color:#fff;display:grid;place-items:center;font:700 34px/1 sans-serif;text-decoration:none}
</style>
<a class="wrap" href="https://www.youtube.com/embed/${youtubeId}?autoplay=1" aria-label="${title}"><span class="play">▶</span></a>`;
---

<section id={section.slug} class="overflow-hidden bg-white text-[#04000a]">
  <div class="relative isolate flex min-h-[320px] items-center justify-center overflow-hidden md:h-[620px]">
    <img class="absolute inset-0 -z-20 h-full w-full object-cover" src={imageSrc(section.hero, 1920)} alt={section.hero.alt || section.title} loading="eager" decoding="async" />
    <div class="absolute inset-0 -z-10 bg-black/45"></div>
    <div class="px-5 text-center text-white">
      <h1 class="text-4xl font-bold uppercase leading-tight md:text-5xl">{section.title}</h1>
      <div class="mt-3 flex items-center justify-center gap-3 text-sm font-bold capitalize md:text-lg">
        {section.gallery.length > 0 && <a href={`#${section.slug}-fotos`} class="transition duration-200 hover:text-[#ff0004]">{photoLabel}</a>}
        {section.gallery.length > 0 && videos.length > 0 && <span>›</span>}
        {videos.length > 0 && <a href={`#${section.slug}-videos`} class="transition duration-200 hover:text-[#ff0004]">{videoLabel}</a>}
      </div>
    </div>
  </div>

  {galleryPages.length > 0 && (
    <div id={`${section.slug}-fotos`} class="mx-auto max-w-[1740px] px-5 py-14 md:px-10 md:py-20">
      <div class="mb-8 flex items-center justify-center gap-4 text-xl font-medium capitalize md:text-2xl">
        <span class="text-[#d60000]">{photoLabel}</span>
        {videos.length > 0 && <><span class="text-[#848484]">›</span><a href={`#${section.slug}-videos`} class="text-[#666666] transition duration-200 hover:text-[#d60000]">{videoLabel}</a></>}
      </div>
      <div class="relative" data-gallery-slider>
        <button class="absolute left-0 top-1/2 z-10 hidden size-12 -translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Fotos anteriores" data-gallery-prev>‹</button>
        <div class="gallery-track flex overflow-x-auto scroll-smooth pb-4" data-gallery-track>
          {galleryPages.map((page, pageIndex) => (
            <div class="grid min-w-full grid-cols-2 gap-4 md:grid-cols-4 md:gap-6" data-gallery-page>
              {page.map((image, imageIndex) => <img class="aspect-[410/524] w-full object-cover" src={imageSrc(image, 820, 1048)} alt={image.alt || `${section.title} ${pageIndex * 8 + imageIndex + 1}`} loading={pageIndex === 0 && imageIndex < 4 ? 'eager' : 'lazy'} decoding="async" />)}
            </div>
          ))}
        </div>
        <button class="absolute right-0 top-1/2 z-10 hidden size-12 translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Fotos siguientes" data-gallery-next>›</button>
      </div>
      <nav class="mt-8 flex justify-center gap-1" aria-label={`Paginación fotos ${section.title}`}>
        {galleryPages.map((_, index) => <button type="button" class="grid size-11 place-items-center rounded-full" aria-label={`Ir a fotos ${index + 1}`} aria-current={index === 0 ? 'page' : undefined} data-gallery-dot><span class={`block size-2.5 rounded-full ${index === 0 ? 'bg-[#ff0004]' : 'bg-[#d9d9d9]'}`} data-gallery-dot-indicator></span></button>)}
      </nav>
    </div>
  )}

  {videos.length > 0 && (
    <div id={`${section.slug}-videos`} class="mx-auto max-w-[1740px] px-5 pb-14 md:px-10 md:pb-20">
      <div class="mb-8 flex items-center justify-center gap-4 text-xl font-medium capitalize md:text-2xl">
        <span class="text-[#d60000]">{videoLabel}</span>
        {galleryPages.length > 0 && <><span class="text-[#848484]">›</span><a href={`#${section.slug}-fotos`} class="text-[#666666] transition duration-200 hover:text-[#d60000]">{photoLabel}</a></>}
      </div>
      <div class="relative" data-gallery-slider>
        <button class="absolute left-0 top-1/2 z-10 hidden size-12 -translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Video anterior" data-gallery-prev>‹</button>
        <div class="gallery-track mx-auto flex overflow-x-auto scroll-smooth" data-gallery-track>
          {videos.map((video) => <div class="relative aspect-video min-w-full overflow-hidden" data-gallery-page><iframe class="h-full w-full" srcdoc={youtubeSrcdoc(video.youtubeId, video.title || section.title, imageSrc(video.image, 1600) || imageSrc(section.hero, 1600) || '')} title={video.title || section.title} loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen /></div>)}
        </div>
        <button class="absolute right-0 top-1/2 z-10 hidden size-12 translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Video siguiente" data-gallery-next>›</button>
      </div>
      <nav class="mt-8 flex justify-center gap-1" aria-label={`Paginación videos ${section.title}`}>
        {videos.map((_, index) => <button type="button" class="grid size-11 place-items-center rounded-full" aria-label={`Ir a video ${index + 1}`} aria-current={index === 0 ? 'page' : undefined} data-gallery-dot><span class={`block size-2.5 rounded-full ${index === 0 ? 'bg-[#ff0004]' : 'bg-[#d9d9d9]'}`} data-gallery-dot-indicator></span></button>)}
      </nav>
    </div>
  )}

  {section.packages?.plans?.length > 0 && (
    <div id={`${section.slug}-paquetes`} class="packages-section mx-auto max-w-[1740px] px-5 pb-24 md:px-10 md:pb-32">
      {section.packages.eyebrow && <p class="packages-eyebrow">{section.packages.eyebrow}</p>}
      {section.packages.title && <h2 class="packages-title">{section.packages.title}</h2>}
      <div class={packageGridClass}>
        {section.packages.plans.map((plan) => (
          <article class="package-card">
            <div class="package-card__head">
              <p>{plan.price}</p>
              <h3>{plan.name}</h3>
            </div>
            <div class="package-card__body">
              <div class="package-card__details">
                {planSections(plan).map((group) => {
                  const items = group.items || [];
                  return (
                    <section>
                      {group.heading && <h4>{group.heading}</h4>}
                      {items.length > 0 && <ul>{items.map((item) => <li>{item}</li>)}</ul>}
                    </section>
                  );
                })}
              </div>
              <a href={whatsappUrl} class={`package-card__cta ${plan.featured ? 'package-card__cta--featured' : ''}`}>{section.packages.ctaLabel || 'Agenda ahora'} <span aria-hidden="true">→</span></a>
            </div>
          </article>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .packages-section {
    padding-top: 10px;
  }

  .packages-eyebrow {
    color: #ff0004;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.18em;
    line-height: 1;
    margin: 0 0 14px;
    text-transform: uppercase;
  }

  .packages-title {
    color: #04000a;
    font-size: clamp(42px, 4.8vw, 58px);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.95;
    margin: 0;
    text-transform: uppercase;
  }

  .packages-grid {
    display: grid;
    gap: 34px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 60px;
  }

  .packages-grid--two,
  .packages-grid--2 {
    grid-template-columns: repeat(2, minmax(0, 397px));
    justify-content: center;
  }

  .packages-grid--3 {
    grid-template-columns: repeat(3, minmax(0, 397px));
    justify-content: center;
  }

  .packages-grid--4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .package-card {
    background: #ffffff;
    border: 1px solid rgba(4, 0, 10, 0.08);
    border-radius: 20px;
    box-shadow: 0 18px 36px rgba(4, 0, 10, 0.08);
    min-height: 708px;
    overflow: hidden;
  }

  .package-card__head {
    background: #ff0004;
    border-radius: 20px 20px 0 0;
    height: 220px;
    isolation: isolate;
    overflow: hidden;
    position: relative;
    text-align: center;
  }

  .package-card__head::before,
  .package-card__head::after {
    bottom: -28px;
    content: "";
    height: 88px;
    left: -8%;
    position: absolute;
    right: -8%;
    transform-origin: center bottom;
  }

  .package-card__head::before {
    background: rgba(255, 255, 255, 0.9);
    clip-path: polygon(0 58%, 22% 70%, 45% 38%, 65% 66%, 100% 42%, 100% 100%, 0 100%);
    z-index: 0;
  }

  .package-card__head::after {
    background: rgba(255, 255, 255, 0.36);
    clip-path: polygon(0 75%, 25% 76%, 49% 45%, 66% 67%, 100% 50%, 100% 100%, 0 100%);
    transform: translateY(18px) scaleX(0.96);
    z-index: 1;
  }

  .package-card__head p {
    color: #ffffff;
    font-size: clamp(36px, 3.8vw, 48px);
    font-weight: 900;
    line-height: 1;
    margin: 70px 0 18px;
    position: relative;
    z-index: 2;
  }

  .package-card__head h3 {
    color: #ffffff;
    font-size: clamp(22px, 2.2vw, 26px);
    font-weight: 900;
    line-height: 1;
    margin: 0;
    position: relative;
    z-index: 2;
  }

  .package-card__body {
    display: flex;
    flex-direction: column;
    min-height: 488px;
    padding: 45px 38px 39px;
  }

  .package-card__details {
    color: #5b5b5b;
    flex: 1;
    font-size: 15px;
    line-height: 1.7;
  }

  .package-card__details section + section {
    margin-top: 14px;
  }

  .package-card__details h4 {
    color: #5b5b5b;
    font-size: 15px;
    font-weight: 900;
    line-height: 1.4;
    margin: 0 0 8px;
  }

  .package-card__details ul {
    list-style: disc;
    margin: 0;
    padding-left: 24px;
  }

  .package-card__details li + li {
    margin-top: 8px;
  }

  .package-card__cta {
    align-items: center;
    border: 1px solid #d0d0d0;
    border-radius: 999px;
    color: #04000a;
    display: inline-flex;
    font-size: 13px;
    font-weight: 900;
    gap: 8px;
    justify-content: center;
    letter-spacing: 0.14em;
    line-height: 1;
    margin-top: 40px;
    min-height: 54px;
    padding: 0 28px;
    text-transform: uppercase;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .package-card__cta:hover {
    border-color: #ff0004;
    color: #ff0004;
    transform: translateY(-2px);
  }

  .package-card__cta--featured {
    background: #ff0004;
    border-color: #ff0004;
    color: #ffffff;
  }

  .package-card__cta--featured:hover {
    background: #e90003;
    color: #ffffff;
  }

  @media (max-width: 900px) {
    .packages-section {
      padding-top: 0;
    }

    .packages-grid,
    .packages-grid--two,
    .packages-grid--3,
    .packages-grid--4 {
      grid-template-columns: 1fr;
      margin-top: 36px;
    }

    .package-card {
      min-height: 0;
    }

    .package-card__head {
      height: 190px;
    }

    .package-card__head p {
      margin-top: 58px;
    }

    .package-card__body {
      min-height: 0;
      padding: 34px 30px 34px;
    }
  }
</style>

<script>
  import '../scripts/gallery-slider.js';
</script>
