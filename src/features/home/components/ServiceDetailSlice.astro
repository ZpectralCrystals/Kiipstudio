---
import {getOptimizedCloudinaryUrl} from '@shared/lib/cloudinary';
import type {SanityImage, ServicePageContent} from '@shared/lib/sanity';

type Props = {
  section: ServicePageContent;
  whatsappUrl: string;
};

const {section, whatsappUrl} = Astro.props;
const imageSrc = (image: SanityImage | undefined, width: number) => getOptimizedCloudinaryUrl(image?.imageUrl, width);
const galleryPages = Array.from({length: Math.ceil(section.gallery.length / 8)}, (_, index) => section.gallery.slice(index * 8, index * 8 + 8));
const videos = section.videos.filter((video) => video.youtubeId);
const photoLabel = section.photoLabel || 'Fotos';
const videoLabel = section.videoLabel || 'Videos';
const youtubeSrcdoc = (youtubeId: string, title: string, posterUrl: string) => `
<style>
*{box-sizing:border-box}body{margin:0}.wrap{position:absolute;inset:0;display:grid;place-items:center;background:#000 url(${posterUrl}) center/cover no-repeat}.wrap:before{content:"";position:absolute;inset:0;background:rgba(0,0,0,.25)}.play{position:relative;width:84px;height:84px;border-radius:999px;background:#ff0004;color:#fff;display:grid;place-items:center;font:700 34px/1 sans-serif;text-decoration:none}
</style>
<a class="wrap" href="https://www.youtube.com/embed/${youtubeId}?autoplay=1" aria-label="${title}"><span class="play">▶</span></a>`;
---

<section id={section.slug} class="overflow-hidden bg-white text-[#04000a]">
  <div class="relative isolate flex min-h-[280px] items-center justify-center overflow-hidden md:min-h-[360px]">
    <img class="absolute inset-0 -z-20 h-full w-full object-cover" src={imageSrc(section.hero, 1920)} alt={section.hero.alt || section.title} loading="eager" decoding="async" />
    <div class="absolute inset-0 -z-10 bg-black/45"></div>
    <div class="px-5 text-center text-white">
      <h1 class="text-4xl font-bold uppercase leading-tight md:text-5xl">{section.title}</h1>
      <div class="mt-3 flex items-center justify-center gap-3 text-sm font-bold capitalize md:text-lg">
        {section.gallery.length > 0 && <a href={`#${section.slug}-fotos`} class="transition duration-200 hover:text-[#ff0004]">{photoLabel}</a>}
        {section.gallery.length > 0 && videos.length > 0 && <span>›</span>}
        {videos.length > 0 && <a href={`#${section.slug}-videos`} class="transition duration-200 hover:text-[#ff0004]">{videoLabel}</a>}
      </div>
    </div>
  </div>

  {galleryPages.length > 0 && (
    <div id={`${section.slug}-fotos`} class="mx-auto max-w-[1290px] px-5 py-14 md:px-8 md:py-20">
      <div class="mb-8 flex items-center justify-center gap-4 text-xl font-medium capitalize md:text-2xl">
        <span class="text-[#d60000]">{photoLabel}</span>
        {videos.length > 0 && <><span class="text-[#848484]">›</span><a href={`#${section.slug}-videos`} class="text-[#666666] transition duration-200 hover:text-[#d60000]">{videoLabel}</a></>}
      </div>
      <div class="relative" data-gallery-slider>
        <button class="absolute left-0 top-1/2 z-10 hidden size-12 -translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Fotos anteriores" data-gallery-prev>‹</button>
        <div class="gallery-track flex overflow-x-auto scroll-smooth pb-4" data-gallery-track>
          {galleryPages.map((page, pageIndex) => (
            <div class="grid min-w-full grid-cols-2 gap-4 md:grid-cols-4 md:gap-6" data-gallery-page>
              {page.map((image, imageIndex) => <img class="aspect-[410/524] w-full object-cover" src={imageSrc(image, 820)} alt={image.alt || `${section.title} ${pageIndex * 8 + imageIndex + 1}`} loading={pageIndex === 0 && imageIndex < 2 ? 'eager' : 'lazy'} decoding="async" />)}
            </div>
          ))}
        </div>
        <button class="absolute right-0 top-1/2 z-10 hidden size-12 translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Fotos siguientes" data-gallery-next>›</button>
      </div>
      <nav class="mt-8 flex justify-center gap-1" aria-label={`Paginación fotos ${section.title}`}>
        {galleryPages.map((_, index) => <button type="button" class="grid size-11 place-items-center rounded-full" aria-label={`Ir a fotos ${index + 1}`} aria-current={index === 0 ? 'page' : undefined} data-gallery-dot><span class={`block size-2.5 rounded-full ${index === 0 ? 'bg-[#ff0004]' : 'bg-[#d9d9d9]'}`} data-gallery-dot-indicator></span></button>)}
      </nav>
    </div>
  )}

  {videos.length > 0 && (
    <div id={`${section.slug}-videos`} class="mx-auto max-w-[1290px] px-5 pb-14 md:px-8 md:pb-20">
      <div class="mb-8 flex items-center justify-center gap-4 text-xl font-medium capitalize md:text-2xl">
        <span class="text-[#d60000]">{videoLabel}</span>
        {galleryPages.length > 0 && <><span class="text-[#848484]">›</span><a href={`#${section.slug}-fotos`} class="text-[#666666] transition duration-200 hover:text-[#d60000]">{photoLabel}</a></>}
      </div>
      <div class="relative" data-gallery-slider>
        <button class="absolute left-0 top-1/2 z-10 hidden size-12 -translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Video anterior" data-gallery-prev>‹</button>
        <div class="gallery-track mx-auto flex overflow-x-auto scroll-smooth" data-gallery-track>
          {videos.map((video) => <div class="relative aspect-video min-w-full overflow-hidden" data-gallery-page><iframe class="h-full w-full" srcdoc={youtubeSrcdoc(video.youtubeId, video.title || section.title, imageSrc(video.image, 1280))} title={video.title || section.title} loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen /></div>)}
        </div>
        <button class="absolute right-0 top-1/2 z-10 hidden size-12 translate-x-8 -translate-y-1/2 place-items-center text-5xl text-[#ff0004] md:grid" type="button" aria-label="Video siguiente" data-gallery-next>›</button>
      </div>
      <nav class="mt-8 flex justify-center gap-1" aria-label={`Paginación videos ${section.title}`}>
        {videos.map((_, index) => <button type="button" class="grid size-11 place-items-center rounded-full" aria-label={`Ir a video ${index + 1}`} aria-current={index === 0 ? 'page' : undefined} data-gallery-dot><span class={`block size-2.5 rounded-full ${index === 0 ? 'bg-[#ff0004]' : 'bg-[#d9d9d9]'}`} data-gallery-dot-indicator></span></button>)}
      </nav>
    </div>
  )}

  {section.packages?.plans?.length > 0 && (
    <div id={`${section.slug}-paquetes`} class="mx-auto max-w-[1080px] px-5 pb-24 md:px-8 md:pb-32">
      {section.packages.eyebrow && <p class="text-xs font-medium uppercase tracking-[0.12em] text-[#d60000]">{section.packages.eyebrow}</p>}
      {section.packages.title && <h2 class="mt-2 text-4xl font-bold uppercase leading-none md:text-5xl">{section.packages.title}</h2>}
      <div class={`mt-10 grid gap-8 ${section.packages.plans.length === 2 ? 'md:grid-cols-2 md:px-40' : 'md:grid-cols-3'}`}>
        {section.packages.plans.map((plan) => (
          <article class="overflow-hidden rounded-[20px] bg-white shadow-[0_4px_20px_-1px_rgba(19,16,34,0.12)] ring-1 ring-black/5">
            <div class="relative isolate flex min-h-44 flex-col items-center justify-center overflow-hidden bg-[#ff0004] px-6 text-center text-white"><div class="absolute inset-x-0 bottom-5 h-12 translate-x-16 skew-x-[-18deg] bg-white/20"></div><div class="absolute inset-x-0 bottom-0 h-10 -translate-x-20 skew-x-[18deg] bg-white/10"></div><p class="relative text-3xl font-bold leading-tight md:text-4xl">{plan.price}</p><h3 class="relative mt-2 text-lg font-bold capitalize md:text-xl">{plan.name}</h3></div>
            <div class="flex min-h-[300px] flex-col px-8 py-8"><ul class="flex-1 list-disc space-y-3 pl-5 text-xs leading-5 text-[#666666]">{plan.bullets.map((bullet) => <li>{bullet}</li>)}</ul><a href={whatsappUrl} class={`mt-8 inline-flex items-center justify-center rounded-full px-6 py-3 text-[11px] font-bold uppercase tracking-[0.12em] transition duration-200 hover:-translate-y-0.5 ${plan.featured ? 'bg-[#ff0004] text-[#04000a] hover:bg-red-500' : 'border border-[#cccccc] text-[#04000a] hover:border-[#d60000] hover:text-[#d60000]'}`}>{section.packages.ctaLabel || 'Agenda ahora'} →</a></div>
          </article>
        ))}
      </div>
    </div>
  )}
</section>

<script>
  import '../scripts/gallery-slider.js';
</script>
