---
import type {HomeLandingContent} from '../data/homeContent';
import {getOptimizedCloudinaryUrl} from '@shared/lib/cloudinary';
import SocialIcon from '@shared/components/SocialIcon.astro';

type Props = {content: HomeLandingContent};
const {content} = Astro.props;
const remoteLogoSrc = 'imageUrl' in content.logo ? content.logo.imageUrl : undefined;
const logoSrc = getOptimizedCloudinaryUrl(typeof remoteLogoSrc === 'string' ? remoteLogoSrc : undefined, 320) || content.logo.localSrc;
const navLabelByHref = (href: string) => content.nav.main.find((item) => item.href === href)?.label ?? '';
const servicesHeading = navLabelByHref('/#servicios');
const aboutHeading = navLabelByHref('/#nosotros');
const contactHeading = content.studio.buttonLabel;
const emailHref = `mailto:${content.footer.email}`;
const phoneHref = `tel:+51${content.footer.phone.replace(/\D/g, '')}`;
const handleHref = (icon: string, href?: string) => {
  if (href) return href;
  const key = icon.trim().toLowerCase();
  return content.footer.socials.find((item) => item.label.toLowerCase() === key || item.text === icon)?.href || '#';
};
---

<footer id="contacto" class="px-5 py-16 md:px-0 md:pb-[164px] md:pt-[140px]">
  <div class="mx-auto max-w-[1290px]">
    <div class="flex min-h-[63px] items-start justify-between border-b border-white/10">
      <img src={logoSrc} alt={content.logo.alt} class="w-32 md:w-[185px]" loading="lazy" decoding="async" width="185" height="53" />
      <nav class="mt-4 flex gap-1 text-sm text-white md:mt-[18px] md:w-[176px] md:justify-between" aria-label="Redes sociales">
        {content.footer.socials.map((item) => <a href={item.href} class="grid size-11 place-items-center rounded-full transition duration-200 hover:opacity-70" aria-label={item.label}><SocialIcon name={item.label} variant="white" class="h-[18px] w-[18px] object-contain" /></a>)}
      </nav>
    </div>
    <div class="grid gap-10 pt-9 text-white md:grid-cols-[230px_160px_360px] md:gap-[148px] md:pt-[39px]">
      <div><h2 class="mb-[26px] font-['Inter'] text-2xl font-bold capitalize leading-[34px]">{servicesHeading}</h2><ul class="space-y-[15px] text-base leading-6 text-white/90">{content.nav.servicios.map((item) => <li><a href={item.href} class="transition duration-200 hover:text-[#ff0004]">{item.label}</a></li>)}</ul></div>
      <div><h2 class="mb-[26px] font-['Inter'] text-2xl font-bold capitalize leading-[34px]">{aboutHeading}</h2><ul class="space-y-[15px] text-base leading-6 text-white/90">{content.nav.nosotros.map((item) => <li><a href={item.href} class="transition duration-200 hover:text-[#ff0004]">{item.label}</a></li>)}</ul></div>
      <div><h2 class="mb-[30px] font-['Inter'] text-2xl font-bold capitalize leading-[34px]">{contactHeading}</h2><ul class="space-y-[10px] text-base font-semibold leading-6 text-white/90"><li><a class="flex items-center gap-[14px] transition duration-200 hover:text-[#ff0004]" href={emailHref}><span class="grid size-10 place-items-center rounded-full border border-white/20"><SocialIcon name="email" class="h-[18px] w-[20px] object-contain" /></span>{content.footer.email}</a></li><li><a class="flex items-center gap-[14px] transition duration-200 hover:text-[#ff0004]" href={phoneHref}><span class="grid size-10 place-items-center rounded-full border border-white/20"><SocialIcon name="phone" class="h-[21px] w-[21px] object-contain" /></span>{content.footer.phone}</a></li>{content.footer.handles.map((item) => <li><a class="flex items-center gap-[14px] transition duration-200 hover:text-[#ff0004]" href={handleHref(item.icon, item.href)}><span class="grid size-10 place-items-center rounded-full border border-white/20"><SocialIcon name={item.icon} class="h-[18px] w-[18px] object-contain" /></span>{item.text}</a></li>)}</ul></div>
    </div>
  </div>
</footer>
