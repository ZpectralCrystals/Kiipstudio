---
import { getCloudinaryImageUrl } from '@shared/lib/cloudinary';

type Props = {
  publicId?: string;
  localMobileSrc?: string;
  localDesktopSrc?: string;
  alt: string;
  mobileWidth?: number;
  desktopWidth?: number;
  intrinsicWidth?: number;
  intrinsicHeight?: number;
  class?: string;
  eager?: boolean;
};

const {
  publicId,
  localMobileSrc,
  localDesktopSrc,
  alt,
  mobileWidth = 720,
  desktopWidth = 1440,
  intrinsicWidth,
  intrinsicHeight,
  class: className = '',
  eager = false,
} = Astro.props;

// Prefer Cloudinary in production. Local WebP fallback keeps Figma replication stable before upload.
const mobile = publicId ? getCloudinaryImageUrl({ publicId, width: mobileWidth }) : localMobileSrc;
const mobile2x = publicId ? getCloudinaryImageUrl({ publicId, width: mobileWidth * 2 }) : localMobileSrc;
const desktop = publicId ? getCloudinaryImageUrl({ publicId, width: desktopWidth }) : localDesktopSrc || localMobileSrc;
const desktop2x = publicId ? getCloudinaryImageUrl({ publicId, width: desktopWidth * 2 }) : localDesktopSrc || localMobileSrc;
---

<picture>
  <source media="(min-width: 768px)" srcset={`${desktop} 1x, ${desktop2x} 2x`} />
  <source media="(max-width: 767px)" srcset={`${mobile} 1x, ${mobile2x} 2x`} />
  <img
    src={desktop}
    alt={alt}
    class={className}
    loading={eager ? 'eager' : 'lazy'}
    decoding="async"
    fetchpriority={eager ? 'high' : 'auto'}
    width={intrinsicWidth}
    height={intrinsicHeight}
  />
</picture>
