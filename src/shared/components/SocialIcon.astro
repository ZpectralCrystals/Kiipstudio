---
type Props = {
  name: string;
  class?: string;
  variant?: 'red' | 'white';
};

const {name, class: className = '', variant = 'red'} = Astro.props;
const key = name.trim().toLowerCase();
const iconNames: Record<string, string> = {
  facebook: 'facebook',
  f: 'facebook',
  tiktok: 'tiktok',
  '♪': 'tiktok',
  instagram: 'instagram',
  '◎': 'instagram',
  whatsapp: 'whatsapp',
  '☏': 'whatsapp',
  email: 'email',
  mail: 'email',
  '✉': 'email',
  phone: 'phone',
  telefono: 'phone',
  teléfono: 'phone',
  '☎': 'phone',
};

const iconName = iconNames[key];
const fileName = variant === 'white' && iconName === 'facebook' ? 'facebook-v2' : iconName;
const src = iconName ? `/assets/social/${variant}/${fileName}.webp` : undefined;
---

{src ? <img class={className} src={src} alt="" aria-hidden="true" width="18" height="21" loading="lazy" decoding="async" /> : <span>{name}</span>}
